# Salin file ini menjadi .env dan isi nilainya

# Connection string dari Neon dashboard (Settings > Connection Details)
DATABASE_URL=postgresql://user:password@ep-xxx-xxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

# String acak yang panjang untuk menandatangani JWT
# Bisa dibuat dengan: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=ganti-dengan-string-rahasia-yang-panjang-dan-acak
